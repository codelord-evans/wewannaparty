NODE_ENV=development
PORT=8787

# Postgres — local Docker, or Supabase for production
# Local:  postgres://wwp:wwp_dev_change_me@localhost:5432/wewannaparty
# Supabase API (pooler): Project Settings → Database → URI → Transaction (port 6543)
# Supabase migrations (optional): Session/direct URI (port 5432)
DATABASE_URL=postgres://wwp:wwp_dev_change_me@localhost:5432/wewannaparty
DATABASE_MIGRATE_URL=
POSTGRES_PASSWORD=wwp_dev_change_me

# Redis (AOF-backed cache, rate limits, inventory holds)
REDIS_URL=redis://:wwp_redis_change_me@localhost:6379/0
REDIS_PASSWORD=wwp_redis_change_me

# Auth — use a long random secret in production (32+ chars)
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-32+
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
INVENTORY_HOLD_TTL_SEC=600

APP_URL=http://localhost:4321
API_PUBLIC_URL=http://localhost:8787

# Paystack (optional — leave empty for local confirm flow)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Email via Resend (optional locally — tickets still show on /success)
# https://resend.com — free tier works; use onboarding@resend.dev until you verify a domain
RESEND_API_KEY=
EMAIL_FROM=WeWannaParty <onboarding@resend.dev>
