---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Wiki | WeWannaParty" description="Guides for fans, promoters, and agents on WeWannaParty.">
  <div class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold">Wiki</h1>
    <p class="mt-2 text-sm text-wwp-muted">Quick answers for buying tickets and running events.</p>
    <div class="mt-8 space-y-3">
      <a href="/event/wer-afro" class="block card-surface p-4 transition hover:border-wwp-red/40">
        <h2 class="font-semibold">How do I buy tickets?</h2>
        <p class="mt-1 text-sm text-wwp-muted">Open an event, select a ticket, pick your spot, and checkout.</p>
      </a>
      <a href="/create-event" class="block card-surface p-4 transition hover:border-wwp-red/40">
        <h2 class="font-semibold">How do I create an event?</h2>
        <p class="mt-1 text-sm text-wwp-muted">Submit your event for review — we handle ticketing infrastructure.</p>
      </a>
      <a href="/terms" class="block card-surface p-4 transition hover:border-wwp-red/40">
        <h2 class="font-semibold">Refunds & policies</h2>
        <p class="mt-1 text-sm text-wwp-muted">Most festival tickets are non-refundable. Check each event page.</p>
      </a>
      <a href="/support" class="block card-surface p-4 transition hover:border-wwp-red/40">
        <h2 class="font-semibold">Still stuck?</h2>
        <p class="mt-1 text-sm text-wwp-muted">Contact support via WhatsApp or email.</p>
      </a>
    </div>
  </div>
</Layout>
