---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="About | WeWannaParty"
  description="WeWannaParty is Africa's ticketing platform built for entertainment culture."
>
  <div class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold sm:text-4xl">About WeWannaParty</h1>
    <div class="mt-6 space-y-4 text-[15px] leading-relaxed text-white/75">
      <p>
        WeWannaParty is Africa&apos;s ticketing platform built for party culture. We help promoters sell out faster,
        track sales in real time, and fill venues — while giving fans a frictionless way to discover and buy tickets.
      </p>
      <p>
        From Uhuru Gardens festivals to intimate club nights, we power the infrastructure behind Kenya&apos;s
        entertainment scene — including partners like WeAreAfro.
      </p>
      <p>Full Performance Cloud Ltd. Nairobi, The 254. Made in Kenya.</p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/create-event" class="rounded-lg bg-wwp-red px-5 py-3 text-sm font-bold text-white uppercase hover:bg-wwp-red-dark"
        >Create an event</a
      >
      <a href="/partner" class="rounded-lg border border-white/20 px-5 py-3 text-sm font-bold text-white uppercase hover:bg-white/5"
        >Partner with us</a
      >
    </div>
  </div>
</Layout>
