---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Partner Us | WeWannaParty" description="Partner with WeWannaParty — sponsorships, venues, and brand collabs.">
  <div class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold">Partner Us</h1>
    <p class="mt-3 text-white/75">
      Brands, venues, and promoters — plug into Kenya&apos;s entertainment culture with WeWannaParty and WeAreAfro.
    </p>
    <ul class="mt-6 space-y-3 text-sm text-white/70">
      <li class="card-surface p-4">Event sponsorship packages & on-site activations</li>
      <li class="card-surface p-4">Venue partnerships and capacity fill programs</li>
      <li class="card-surface p-4">Co-branded festival experiences</li>
    </ul>
    <a href="/support" class="mt-8 inline-flex rounded-lg bg-wwp-red px-5 py-3 text-sm font-bold text-white uppercase hover:bg-wwp-red-dark">
      Talk to partnerships
    </a>
  </div>
</Layout>
