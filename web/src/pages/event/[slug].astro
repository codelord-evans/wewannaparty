---
import Layout from "../../layouts/Layout.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import EventInfoItem from "../../components/EventInfoItem.astro";
import TicketSelector from "../../components/TicketSelector";
import { events } from "../../../../packages/shared/src/data.ts";
import { formatDoors, formatEventDate, formatTimeRange } from "../../lib/format";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const title = `${event.name} | WeWannaParty`;
const description = event.description;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${event.venue_name}, ${event.location}`)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  name: event.name,
  description: event.description,
  image: event.poster,
  startDate: `${event.date}T${event.start_time}`,
  endDate: `${event.date}T${event.end_time}`,
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: event.venue_name,
    address: event.location,
  },
  organizer: {
    "@type": "Organization",
    name: event.organizer ?? "WeWannaParty",
  },
  offers: event.tickets
    .filter((t) => t.available)
    .map((t) => ({
      "@type": "Offer",
      name: t.name,
      price: t.price_kes,
      priceCurrency: "KES",
      availability: "https://schema.org/InStock",
      url: `https://wewannaparty.local/event/${event.slug}`,
    })),
  performer: event.artists.map((a) => ({
    "@type": "MusicGroup",
    name: a.name,
  })),
};
---

<Layout title={title} description={description} image={event.poster} jsonLd={jsonLd}>
  {/* Hero */}
  <section class="relative h-[220px] overflow-hidden sm:h-[280px] lg:h-[320px]">
    <img
      src={event.poster}
      alt=""
      class="absolute inset-0 h-full w-full scale-110 object-cover blur-md brightness-[0.45]"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-wwp-black via-black/40 to-black/20"></div>
    <img
      src={event.poster}
      alt={event.name}
      class="absolute inset-0 m-auto h-full w-auto max-w-[90%] object-contain drop-shadow-2xl sm:max-w-[70%] lg:max-w-[520px]"
    />

    <div class="absolute inset-x-0 top-0 z-10 mx-auto flex max-w-[1400px] items-center justify-between px-4 pt-4 lg:px-6">
      <a
        href="/events"
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/40 px-3 py-1.5 text-xs font-medium text-white backdrop-blur hover:bg-black/60"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        Back to Events
      </a>
      <div class="flex items-center gap-2">
        <button
          type="button"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/15 bg-black/40 text-white backdrop-blur hover:bg-black/60"
          aria-label="Share"
          id="share-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"></path>
          </svg>
        </button>
        <button
          type="button"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/15 bg-black/40 text-white backdrop-blur hover:bg-black/60"
          aria-label="Favorite"
          id="fav-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path
              d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <div class="mx-auto grid max-w-[1400px] gap-6 px-4 py-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:gap-8 lg:px-6 lg:py-8 xl:grid-cols-[minmax(0,1fr)_380px]">
    <div class="min-w-0 space-y-5">
      {/* Event header */}
      <section class="card-surface p-5 sm:p-6">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-wwp-red px-2.5 py-1 text-[10px] font-bold tracking-wide text-white uppercase">
            {event.organizer ?? "Admission"}
          </span>
          <span class="rounded-full border border-wwp-border bg-wwp-surface px-2.5 py-1 text-[10px] font-semibold tracking-wide text-white/70 capitalize">
            {event.category}
          </span>
        </div>
        <h1 class="mt-3 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {event.name}
        </h1>
        <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-white/75">
          <span class="inline-flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-wwp-red">
              <rect x="3" y="4" width="18" height="18" rx="2"></rect>
              <path d="M16 2v4M8 2v4M3 10h18"></path>
            </svg>
            {formatEventDate(event.date)}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-wwp-red">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M12 7v5l3 2"></path>
            </svg>
            {formatTimeRange(event.start_time, event.end_time)}
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-wwp-red">
              <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"></path>
              <circle cx="12" cy="10" r="2.5"></circle>
            </svg>
            {event.venue_name}
          </span>
          <span class="inline-flex items-center rounded border border-wwp-red/40 bg-wwp-red/10 px-2 py-0.5 text-xs font-bold text-wwp-red">
            {event.age_restriction}
          </span>
        </div>
      </section>

      <section class="card-surface p-5 sm:p-6">
        <h2 class="font-display text-xl font-semibold">About This Event</h2>
        <p class="mt-3 text-sm leading-relaxed text-white/75 sm:text-[15px]">{event.description}</p>
      </section>

      <section class="card-surface p-5 sm:p-6">
        <h2 class="font-display text-xl font-semibold">Event Information</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <EventInfoItem label="Doors Open" value={formatDoors(event.doors_open)} />
          <EventInfoItem label="Dress code" value={event.dress_code} />
          <EventInfoItem label="Age restriction" value={event.age_restriction} />
          <EventInfoItem label="Parking" value={event.parking ?? "Available (Limited)"} />
        </div>
      </section>

      <section class="card-surface p-5 sm:p-6">
        <h2 class="flex items-center gap-2 font-display text-xl font-semibold">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-wwp-red">
            <path d="M9 18V5l12-2v13"></path>
            <circle cx="6" cy="18" r="3"></circle>
            <circle cx="18" cy="16" r="3"></circle>
          </svg>
          Featured Artists
        </h2>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {
            event.artists.map((artist) => (
              <ArtistCard
                name={artist.name}
                genre={artist.genre}
                photoUrl={artist.photo_url}
                instagramUrl={artist.instagram_url}
              />
            ))
          }
        </div>
      </section>

      <section class="card-surface p-5 sm:p-6">
        <h2 class="font-display text-xl font-semibold">Venue</h2>
        <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
          <p class="inline-flex items-center gap-2 text-sm text-white/80">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-wwp-red">
              <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"></path>
              <circle cx="12" cy="10" r="2.5"></circle>
            </svg>
            {event.venue_name}, {event.location}
          </p>
          <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-wwp-red hover:underline">
            Get Directions
          </a>
        </div>
      </section>
    </div>

    <div class="lg:min-h-[640px]">
      <TicketSelector
        client:load
        tickets={event.tickets}
        eventSlug={event.slug}
        ctaLabel="BUY YOUR SPOT"
      />
    </div>
  </div>
</Layout>

<script>
  document.getElementById("share-btn")?.addEventListener("click", async () => {
    const shareData = { title: document.title, url: location.href };
    if (navigator.share) {
      await navigator.share(shareData);
    } else {
      await navigator.clipboard.writeText(location.href);
      alert("Link copied to clipboard");
    }
  });

  document.getElementById("fav-btn")?.addEventListener("click", (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.classList.toggle("text-wwp-red");
  });
</script>
