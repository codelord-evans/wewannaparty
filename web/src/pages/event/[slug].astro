---
import Layout from "../../layouts/Layout.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import EventInfoItem from "../../components/EventInfoItem.astro";
import TicketSelector from "../../components/TicketSelector";
import { events } from "../../../../packages/shared/src/data.ts";
import { formatDoors, formatEventDate, formatTimeRange } from "../../lib/format";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const title = `${event.name} | WeWannaParty`;
const description = event.description;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${event.venue_name}, ${event.location}`)}`;

/** Packages that use the floor/spot picker (premium table/suite tiers) */
const spotTicketIds = event.tickets
  .filter((t) => /package|suite|lounge|royale|experience/i.test(t.name))
  .map((t) => t.id);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicEvent",
  name: event.name,
  description: event.description,
  image: event.poster,
  startDate: `${event.date}T${event.start_time}`,
  endDate: `${event.date}T${event.end_time}`,
  eventStatus: "https://schema.org/EventScheduled",
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  location: {
    "@type": "Place",
    name: event.venue_name,
    address: event.location,
  },
  organizer: {
    "@type": "Organization",
    name: event.organizer ?? "WeWannaParty",
  },
  offers: event.tickets
    .filter((t) => t.available)
    .map((t) => ({
      "@type": "Offer",
      name: t.name,
      price: t.price_kes,
      priceCurrency: "KES",
      availability: "https://schema.org/InStock",
      url: `https://wewannaparty.local/event/${event.slug}`,
    })),
  performer: event.artists.map((a) => ({
    "@type": "MusicGroup",
    name: a.name,
  })),
};
---

<Layout title={title} description={description} image={event.poster} jsonLd={jsonLd}>
  <div class="min-h-screen bg-background pt-20">
    {/* Hero — matched: h-[40vh] md:h-[50vh], poster opacity-70, gradient overlays */}
    <section class="relative h-[40vh] overflow-hidden md:h-[50vh]">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/40 via-primary/20 to-background"></div>
      <img
        src={event.poster}
        alt={event.name}
        class="absolute inset-0 h-full w-full object-cover opacity-70"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent"></div>

      <a
        href="/events"
        class="absolute top-6 left-6 z-10 flex items-center gap-2 rounded-full bg-background/20 px-4 py-2 text-foreground/80 backdrop-blur-sm transition-colors hover:text-foreground"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"></path>
        </svg>
        <span class="text-sm font-medium">Back to Events</span>
      </a>

      <div class="absolute top-6 right-6 z-10 flex items-center gap-2">
        <button
          type="button"
          id="share-btn"
          aria-label="Share"
          class="rounded-full bg-background/20 p-3 text-foreground backdrop-blur-sm transition-all duration-300 hover:bg-primary/80 hover:text-primary-foreground"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"></path>
          </svg>
        </button>
        <button
          type="button"
          id="fav-btn"
          aria-label="Save"
          class="rounded-full bg-background/20 p-3 text-foreground backdrop-blur-sm transition-colors hover:bg-background/40"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path
              d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"
            ></path>
          </svg>
        </button>
      </div>
    </section>

    {/* Content overlaps hero — matched: max-w-6xl -mt-32 */}
    <div class="relative z-10 mx-auto -mt-32 max-w-6xl px-4 pb-16">
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="space-y-6 lg:col-span-2">
          {/* Event header card */}
          <section class="rounded-2xl border border-border bg-card p-6 md:p-8">
            <div class="mb-4 flex flex-wrap items-center gap-2">
              <span class="inline-block rounded-full bg-primary/20 px-3 py-1 text-sm font-medium text-primary">
                {event.organizer ?? "WeAreAfro"}
              </span>
              <span class="inline-block rounded-full bg-muted/40 px-3 py-1 text-sm font-medium text-foreground capitalize">
                {event.category}
              </span>
              <span class="inline-block rounded-full bg-accent px-3 py-1 text-sm font-bold text-accent-foreground">
                {event.age_restriction}
              </span>
            </div>

            <h1 class="mb-4 font-display text-3xl font-bold text-foreground md:text-4xl">
              {event.name}
            </h1>

            <div class="grid grid-cols-2 gap-4 text-sm md:grid-cols-4">
              <div class="flex items-center gap-2 text-muted-foreground">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-primary">
                  <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                  <path d="M16 2v4M8 2v4M3 10h18"></path>
                </svg>
                <span>{formatEventDate(event.date)}</span>
              </div>
              <div class="flex items-center gap-2 text-muted-foreground">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-primary">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M12 7v5l3 2"></path>
                </svg>
                <span>{formatTimeRange(event.start_time, event.end_time)}</span>
              </div>
              <div class="flex items-center gap-2 text-muted-foreground">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-primary">
                  <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"></path>
                  <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
                <span>{event.venue_name}</span>
              </div>
              <div class="flex items-center gap-2 text-muted-foreground">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-primary">
                  <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                <span>{event.age_restriction}</span>
              </div>
            </div>
          </section>

          <section class="rounded-2xl border border-border bg-card p-6 md:p-8">
            <h2 class="mb-4 font-display text-xl font-bold text-foreground">About This Event</h2>
            <p class="leading-relaxed text-muted-foreground">{event.description}</p>
          </section>

          <section class="rounded-2xl border border-border bg-card p-6 md:p-8">
            <h2 class="mb-4 font-display text-xl font-bold text-foreground">Event Information</h2>
            <div class="grid gap-4 md:grid-cols-2">
              <EventInfoItem label="Doors Open" value={formatDoors(event.doors_open)} />
              <EventInfoItem label="Dress Code" value={event.dress_code} />
              <EventInfoItem label="Age Restriction" value={event.age_restriction} />
              <EventInfoItem label="Refund Policy" value={event.refund_policy} />
            </div>
          </section>

          {
            event.artists.length > 0 && (
              <section class="rounded-2xl border border-border bg-card p-6 md:p-8">
                <h2 class="mb-6 flex items-center gap-2 font-display text-xl font-bold text-foreground">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary" aria-hidden>
                    <path d="M9 18V5l12-2v13"></path>
                    <circle cx="6" cy="18" r="3"></circle>
                    <circle cx="18" cy="16" r="3"></circle>
                  </svg>
                  Featured Artists
                </h2>
                <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
                  {event.artists.map((artist) => (
                    <ArtistCard
                      name={artist.name}
                      genre={artist.genre}
                      photoUrl={artist.photo_url}
                      instagramUrl={artist.instagram_url}
                    />
                  ))}
                </div>
              </section>
            )
          }

          <section class="rounded-2xl border border-border bg-card p-6 md:p-8">
            <h2 class="mb-4 font-display text-xl font-bold text-foreground">Venue</h2>
            <div class="flex items-start gap-3">
              <div class="rounded-xl bg-primary/20 p-3">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary">
                  <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"></path>
                  <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
              </div>
              <div>
                <p class="text-lg font-bold text-foreground">{event.venue_name}</p>
                <p class="text-muted-foreground">{event.location}</p>
                <a
                  href={mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-2 inline-block text-sm font-semibold text-primary hover:underline"
                >
                  Get Directions
                </a>
              </div>
            </div>
          </section>
        </div>

        <div class="lg:col-span-1">
          <TicketSelector client:load tickets={event.tickets} eventSlug={event.slug} spotTicketIds={spotTicketIds} />
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById("share-btn")?.addEventListener("click", async () => {
    const shareData = { title: document.title, url: location.href };
    if (navigator.share) {
      await navigator.share(shareData);
    } else {
      await navigator.clipboard.writeText(location.href);
      alert("Link copied to clipboard");
    }
  });

  document.getElementById("fav-btn")?.addEventListener("click", (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.classList.toggle("text-primary");
  });
</script>
