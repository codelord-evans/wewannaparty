---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Privacy Policy | WeWannaParty" description="How WeWannaParty collects, uses, and protects your data.">
  <div class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold">Privacy Policy</h1>
    <div class="mt-6 space-y-4 text-sm leading-relaxed text-white/75">
      <p>
        We collect information you provide when creating an account, purchasing tickets, or contacting support —
        including name, email, phone number, and payment details processed by our payment partners.
      </p>
      <p>
        We use this data to fulfill orders, prevent fraud, improve the platform, and communicate about your bookings.
        We do not sell your personal data.
      </p>
      <p>
        For privacy requests, contact <a href="mailto:support@wewannaparty.africa" class="text-wwp-red hover:underline"
          >support@wewannaparty.africa</a
        >.
      </p>
    </div>
  </div>
</Layout>
