---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Support | WeWannaParty" description="Get help with tickets, refunds, and event support.">
  <div class="mx-auto max-w-2xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold">Support / Help Center</h1>
    <p class="mt-2 text-sm text-wwp-muted">Questions about your order? We&apos;re here.</p>

    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <a href="https://wa.me/254112438856" target="_blank" rel="noopener" class="card-surface p-4 transition hover:border-wwp-red/40">
        <p class="font-semibold">WhatsApp</p>
        <p class="mt-1 text-sm text-wwp-muted">+254 112 438 856</p>
      </a>
      <a href="mailto:support@wewannaparty.africa" class="card-surface p-4 transition hover:border-wwp-red/40">
        <p class="font-semibold">Email</p>
        <p class="mt-1 text-sm text-wwp-muted">support@wewannaparty.africa</p>
      </a>
    </div>

    <form id="support-form" class="card-surface mt-8 space-y-4 p-6">
      <label class="block">
        <span class="mb-1.5 block text-xs text-wwp-muted">Name</span>
        <input name="name" required class="w-full rounded-lg border border-wwp-border bg-wwp-surface px-3 py-2.5 text-sm outline-none focus:border-wwp-red/60" />
      </label>
      <label class="block">
        <span class="mb-1.5 block text-xs text-wwp-muted">Email</span>
        <input name="email" type="email" required class="w-full rounded-lg border border-wwp-border bg-wwp-surface px-3 py-2.5 text-sm outline-none focus:border-wwp-red/60" />
      </label>
      <label class="block">
        <span class="mb-1.5 block text-xs text-wwp-muted">Order ID (optional)</span>
        <input name="orderId" class="w-full rounded-lg border border-wwp-border bg-wwp-surface px-3 py-2.5 text-sm outline-none focus:border-wwp-red/60" />
      </label>
      <label class="block">
        <span class="mb-1.5 block text-xs text-wwp-muted">Message</span>
        <textarea name="message" rows="4" required class="w-full rounded-lg border border-wwp-border bg-wwp-surface px-3 py-2.5 text-sm outline-none focus:border-wwp-red/60"></textarea>
      </label>
      <p id="support-msg" class="hidden text-sm"></p>
      <button type="submit" class="w-full rounded-lg bg-wwp-red py-3 text-sm font-bold tracking-wide text-white uppercase hover:bg-wwp-red-dark">
        Send message
      </button>
    </form>
  </div>
</Layout>

<script>
  const API = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8787";
  const form = document.getElementById("support-form") as HTMLFormElement;
  const msg = document.getElementById("support-msg")!;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form).entries());
    msg.classList.remove("hidden", "text-wwp-red", "text-green-400");
    try {
      const res = await fetch(`${API}/api/contact`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error || "Failed");
      msg.textContent = `${json.message} (${json.ticketId})`;
      msg.classList.add("text-green-400");
      form.reset();
    } catch (err) {
      msg.textContent = err instanceof Error ? err.message : "Something went wrong";
      msg.classList.add("text-wwp-red");
    }
  });
</script>
