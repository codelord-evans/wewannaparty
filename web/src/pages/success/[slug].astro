---
import Layout from "../../layouts/Layout.astro";
import TicketDownload from "../../components/TicketDownload";
import { events } from "../../../../packages/shared/src/data.ts";

export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
---

<Layout
  bare
  title={`Your ticket · ${event.name} | WeWannaParty`}
  description={`Electronic ticket for ${event.name}`}
>
  <TicketDownload client:load eventSlug={event.slug} eventName={event.name} />
</Layout>

<style is:global>
  @media print {
    body {
      background: #000 !important;
    }
    header,
    footer {
      display: none !important;
    }
  }
</style>
