---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Terms of Service | WeWannaParty" description="Terms governing use of the WeWannaParty ticketing platform.">
  <div class="mx-auto max-w-3xl px-4 py-12 lg:px-6">
    <h1 class="font-display text-3xl font-bold">Terms of Service</h1>
    <div class="prose-invert mt-6 space-y-4 text-sm leading-relaxed text-white/75">
      <p>By purchasing tickets or creating an account on WeWannaParty, you agree to these terms.</p>
      <h2 class="font-display text-lg font-semibold text-white">Tickets</h2>
      <p>
        All ticket sales are subject to the event organizer&apos;s refund policy. Unless otherwise stated, tickets for
        We*R Afro and similar events are non-refundable.
      </p>
      <h2 class="font-display text-lg font-semibold text-white">Account use</h2>
      <p>You are responsible for keeping your login credentials secure and for all activity under your account.</p>
      <h2 class="font-display text-lg font-semibold text-white">Payments</h2>
      <p>
        Payments may be processed via M-Pesa, card, or other supported methods. Service fees may apply per ticket.
      </p>
      <h2 class="font-display text-lg font-semibold text-white">Contact</h2>
      <p>Questions? Reach us via <a href="/support" class="text-wwp-red hover:underline">Support</a>.</p>
    </div>
  </div>
</Layout>
