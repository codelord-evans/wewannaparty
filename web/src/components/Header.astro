---
const pathname = Astro.url.pathname;

const links = [
  { href: "/events", label: "Events" },
  { href: "/gallery", label: "Gallery" },
  { href: "/wiki", label: "Wiki" },
  { href: "/create-event", label: "Create Event" },
  { href: "/about", label: "About" },
  { href: "/partner", label: "Partner Us" },
  { href: "/agent", label: "Agent Portal" },
  { href: "/support", label: "Support" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-border/60 bg-background/90 backdrop-blur-md">
  <div class="mx-auto flex h-20 max-w-6xl items-center justify-between gap-4 px-4">
    <a href="/" class="group flex shrink-0 items-center gap-2">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary font-display text-sm font-extrabold text-primary-foreground"
        aria-hidden="true"
      >
        W
      </span>
      <span class="font-display text-sm font-bold tracking-tight sm:text-base">
        <span class="text-foreground">WeWannaParty</span>
        <span class="mx-1 text-primary">X</span>
        <span class="text-foreground/90">WeAreAfro</span>
      </span>
    </a>

    <nav class="hidden items-center gap-6 xl:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors hover:text-foreground",
              pathname === link.href || pathname.startsWith(link.href + "/")
                ? "text-foreground"
                : "text-muted-foreground",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        id="mobile-nav-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border text-foreground xl:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
      <a
        href="/auth"
        class="rounded-lg bg-primary px-4 py-2.5 text-xs font-bold tracking-wide text-primary-foreground uppercase transition hover:bg-primary/90"
      >
        Create Account
      </a>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-border bg-background px-4 py-3 xl:hidden">
    <div class="flex flex-col gap-1">
      {
        links.map((link) => (
          <a href={link.href} class="rounded-lg px-3 py-2.5 text-sm text-muted-foreground hover:bg-muted/40 hover:text-foreground">
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
