---
interface Props {
  id: number;
  name: string;
  slug: string;
  poster: string;
  venue: string;
  location: string;
  date: string;
  priceMin: string;
  priceMax: string;
  badge?: string;
}

import { formatEventDate, formatKes } from "../lib/format";

const { name, slug, poster, venue, location, date, priceMin, priceMax, badge } = Astro.props;
const priceLabel =
  priceMin === priceMax
    ? formatKes(Number(priceMin))
    : `${formatKes(Number(priceMin))} – ${formatKes(Number(priceMax))}`;
---

<a
  href={`/event/${slug}`}
  class="group overflow-hidden rounded-xl border border-wwp-border bg-wwp-card transition hover:border-wwp-red/50"
>
  <div class="relative aspect-[4/5] overflow-hidden">
    <img
      src={poster}
      alt={name}
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      loading="lazy"
    />
    {
      badge && (
        <span class="absolute top-3 left-3 rounded-full bg-wwp-red px-2.5 py-1 text-[10px] font-bold tracking-wide text-white uppercase">
          {badge.replace("_", " ")}
        </span>
      )
    }
  </div>
  <div class="p-4">
    <h3 class="font-display text-lg font-semibold text-white">{name}</h3>
    <p class="mt-1 text-sm text-wwp-muted">{formatEventDate(date)}</p>
    <p class="mt-1 text-sm text-white/70">{venue} · {location}</p>
    <p class="mt-3 text-sm font-semibold text-wwp-red">{priceLabel}</p>
  </div>
</a>
