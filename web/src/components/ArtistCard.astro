---
interface Props {
  name: string;
  genre: string;
  photoUrl: string;
  instagramUrl?: string;
}

const { name, genre, photoUrl, instagramUrl } = Astro.props;
---

<a
  href={instagramUrl || "#"}
  target={instagramUrl ? "_blank" : undefined}
  rel={instagramUrl ? "noopener noreferrer" : undefined}
  class="group cursor-pointer"
>
  <div class="relative mb-3 aspect-square overflow-hidden rounded-xl">
    <img
      src={photoUrl}
      alt={name}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
      loading="lazy"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    >
    </div>
    {
      instagramUrl && (
        <div class="absolute right-2 bottom-2 left-2 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <span class="flex items-center justify-center gap-2 rounded-lg bg-primary/90 px-3 py-2 text-sm font-medium text-primary-foreground backdrop-blur-sm">
            View on Instagram
          </span>
        </div>
      )
    }
  </div>
  <div class="text-center">
    <h3 class="font-semibold text-foreground">{name}</h3>
    <p class="text-sm text-muted-foreground">{genre}</p>
  </div>
</a>
