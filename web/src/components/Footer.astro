---
const links = [
  { href: "/events", label: "Events" },
  { href: "/gallery", label: "Gallery" },
  { href: "/create-event", label: "Create Event" },
  { href: "/about", label: "About" },
  { href: "/support", label: "Support" },
  { href: "/terms", label: "Terms" },
  { href: "/privacy", label: "Privacy" },
];
---

<footer class="mt-auto border-t border-border bg-background">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div>
        <a href="/" class="inline-flex items-center gap-2 font-display text-lg font-bold tracking-tight">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-sm font-extrabold text-primary-foreground"
            >W</span
          >
          WeWanna<span class="text-primary">Party</span>
        </a>
        <p class="mt-2 max-w-xs text-sm text-muted-foreground">The ultimate ticketing platform.</p>
      </div>
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer">
        {
          links.map((link) => (
            <a href={link.href} class="text-sm text-muted-foreground transition hover:text-foreground">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
    <p class="text-sm text-muted-foreground text-center md:text-left">
      Built, Designed and Curated By Migel Mbai & Luke Akolade.
      <br />
      © {new Date().getFullYear()} WeWannaParty. All rights reserved.
    </p>
  </div>
</footer>
